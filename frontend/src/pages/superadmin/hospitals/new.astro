---
import Base from '../../../layouts/Base.astro';

const API   = import.meta.env.PUBLIC_API_URL ?? 'http://localhost:8000';
const token = Astro.cookies.get('nas_token')?.value;

let error = '';

if (Astro.request.method === 'POST') {
  try {
    const form         = await Astro.request.formData();
    const hospital_name = form.get('hospital_name') as string;
    const username      = form.get('username') as string;
    const password      = form.get('password') as string;
    const full_name     = (form.get('full_name') as string) || null;

    const res = await fetch(`${API}/auth/register/admin`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', Authorization: `Bearer ${token}` },
      body: JSON.stringify({ hospital_name, username, password, full_name }),
    });

    if (res.ok) {
      return Astro.redirect('/superadmin');
    } else {
      const err = await res.json().catch(() => ({}));
      error = err.detail ?? `Server error ${res.status}`;
    }
  } catch (e: any) {
    error = e.message ?? 'Unexpected error';
  }
}
---

<Base title="Add Hospital">
  <div class="page" style="max-width:560px;">
    <div style="margin-bottom:24px;">
      <a href="/superadmin" style="font-size:0.8rem; color:var(--charcoal-muted); display:inline-flex; align-items:center; gap:4px; margin-bottom:12px;">
        ← Super Admin
      </a>
      <h1>Add Hospital</h1>
      <p style="font-size:0.85rem; color:var(--charcoal-muted); margin-top:4px;">
        Register a new hospital and create its admin account in one step.
      </p>
    </div>

    {error && (
      <div style="background:var(--red-bg); color:var(--red-text); border:1px solid #fecaca; border-radius:var(--radius-card); padding:14px 18px; margin-bottom:20px; font-size:0.85rem;">
        {error}
      </div>
    )}

    <form method="POST">
      <div class="card" style="margin-bottom:16px;">
        <div class="card-header"><h2>Hospital</h2></div>
        <div class="card-body">
          <div class="form-group" style="margin-bottom:0;">
            <label class="form-label">Hospital Name *</label>
            <input class="form-input" type="text" name="hospital_name" placeholder="e.g. Tamale Teaching Hospital" required />
          </div>
        </div>
      </div>

      <div class="card" style="margin-bottom:24px;">
        <div class="card-header">
          <h2>Admin Account</h2>
          <span style="font-size:0.78rem; color:var(--charcoal-muted);">This person manages the hospital's staff</span>
        </div>
        <div class="card-body">
          <div class="form-group">
            <label class="form-label">Full Name</label>
            <input class="form-input" type="text" name="full_name" placeholder="e.g. Dr. Kofi Mensah" />
          </div>
          <div class="form-group">
            <label class="form-label">Username *</label>
            <input class="form-input" type="text" name="username" placeholder="e.g. tamale_admin" required autocomplete="off" />
          </div>
          <div class="form-group" style="margin-bottom:0;">
            <label class="form-label">Password *</label>
            <input class="form-input" type="password" name="password" placeholder="Minimum 8 characters" required minlength="8" autocomplete="new-password" />
          </div>
        </div>
      </div>

      <div style="display:flex; gap:12px; justify-content:flex-end; margin-bottom:40px;">
        <a href="/superadmin" class="btn btn-outline">Cancel</a>
        <button type="submit" class="btn btn-primary">Create Hospital →</button>
      </div>
    </form>
  </div>
</Base>
