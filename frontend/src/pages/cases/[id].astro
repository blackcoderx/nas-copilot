---
import Base from '../../layouts/Base.astro';

const API = import.meta.env.PUBLIC_API_URL ?? 'http://localhost:8000';
const token = Astro.cookies.get('nas_token')?.value;
const { id } = Astro.params;

let data: any = null;
let fetchError = '';

try {
  const res = await fetch(`${API}/cases/${id}`, {
    headers: { Authorization: `Bearer ${token}` },
  });
  if (res.ok) data = await res.json();
  else if (res.status === 401) return Astro.redirect('/login');
  else fetchError = res.status === 404 ? 'Case not found' : `API error ${res.status}`;
} catch {
  fetchError = 'Could not reach backend';
}

const c = data?.case;
const gen = data?.latest_generation;
const flags: any[] = gen?.flags ?? [];
const triage = gen?.triage_json ?? null;

// Fetch outcome for share link (non-critical)
let outcome: any = null;
if (c?.outcome_token) {
  try {
    const outRes = await fetch(`${API}/outcomes/${c.outcome_token}`);
    if (outRes.ok) { const outData = await outRes.json(); outcome = outData?.outcome ?? null; }
  } catch { /* non-critical */ }
}

function fmtDate(iso: string) {
  return new Date(iso).toLocaleString('en-GB', {
    day: '2-digit', month: 'short', year: 'numeric',
    hour: '2-digit', minute: '2-digit',
  });
}

const route = gen?.route_json;
const weather = gen?.weather_json;
const facilities: any[] = gen?.facilities_json ?? [];

function fmtVitals(v: any) {
  if (!v) return null;
  const parts: string[] = [];
  if (v.bp_sys != null && v.bp_dia != null) parts.push(`BP ${v.bp_sys}/${v.bp_dia}`);
  if (v.hr != null)   parts.push(`HR ${v.hr}`);
  if (v.rr != null)   parts.push(`RR ${v.rr}`);
  if (v.spo2 != null) parts.push(`SpO₂ ${v.spo2}%`);
  if (v.temp_c != null) parts.push(`Temp ${v.temp_c}°C`);
  if (v.gcs != null)  parts.push(`GCS ${v.gcs}`);
  if (v.pain != null) parts.push(`Pain ${v.pain}/10`);
  return parts.join(' · ') || null;
}

const v1 = c?.vitals_set_1;
const v2 = c?.vitals_set_2;

function wxLine(wx: any) {
  if (!wx) return 'Unavailable';
  return `${wx.condition ?? '?'} · ${wx.temperature_c ?? '?'}°C · Wind ${wx.wind_kmh ?? '?'} km/h`;
}

const severityOrder: Record<string, number> = { high: 0, medium: 1, low: 2 };
const sortedFlags = [...flags].sort((a, b) =>
  (severityOrder[a.severity] ?? 9) - (severityOrder[b.severity] ?? 9)
);

const hasOps = route || weather?.pickup || weather?.destination || facilities.length > 0;

// Triage colour helpers (computed in frontmatter to avoid type annotations inside JSX)
const triageColors: Record<string, string> = { red: '#dc2626', orange: '#d97706', yellow: '#ca8a04', green: '#16a34a' };
const triageBg: Record<string, string>     = { red: 'var(--red-bg)', orange: '#fff7ed', yellow: '#fefce8', green: 'var(--green-soft)' };
const triageCol = triage ? (triageColors[triage.color] ?? 'var(--charcoal)') : '';
const triageBgc = triage ? (triageBg[triage.color]    ?? 'var(--surface)')  : '';
---

<Base title={c ? c.complaint : 'Case'}>
  <div class="page">
    {fetchError && (
      <div style="background:var(--red-bg); color:var(--red-text); border:1px solid #fecaca; border-radius:var(--radius-card); padding:14px 18px; font-size:0.85rem;">
        {fetchError}
      </div>
    )}

    {c && (
      <>
        <!-- Header -->
        <div style="display:flex; align-items:flex-start; justify-content:space-between; gap:16px; margin-bottom:24px; flex-wrap:wrap;">
          <div>
            <a href="/dashboard" style="font-size:0.8rem; color:var(--charcoal-muted); display:inline-flex; align-items:center; gap:4px; margin-bottom:8px;">
              ← Dashboard
            </a>
            <div style="display:flex; align-items:center; gap:10px;">
              <h1 style="font-size:1.2rem;">{c.complaint}</h1>
              <span class={`badge badge-${c.status.toLowerCase()}`}>{c.status}</span>
            </div>
            <div style="font-size:0.8rem; color:var(--charcoal-muted); margin-top:4px;">
              {c.pickup} → {c.destination} · {fmtDate(c.created_at)}
            </div>
          </div>
          <div style="display:flex; gap:8px; flex-wrap:wrap;">
            {c.status !== 'FINAL' && (
              <button
                id="btn-generate"
                class="btn btn-generate"
                onclick={`handleGenerate('${id}')`}
              >
                <span id="gen-label">Generate PCR</span>
                <span id="gen-spinner" class="spinner" style="display:none;"></span>
              </button>
            )}
            {c.status !== 'FINAL' && (
              <button class="btn btn-outline" onclick={`handleFinalize('${id}')`}>
                Finalize
              </button>
            )}
            <a href={`${API}/cases/${id}/export`} class="btn btn-outline" target="_blank">
              Export JSON
            </a>
          </div>
        </div>

        <!-- Error banner (JS populated) -->
        <div id="action-error" style="display:none; background:var(--red-bg); color:var(--red-text); border:1px solid #fecaca; border-radius:var(--radius-card); padding:12px 16px; margin-bottom:16px; font-size:0.84rem;"></div>

        <div style="display:flex; flex-direction:column; gap:16px;">

          <!-- Time Chain -->
          <div class="card">
            <div class="card-header"><h2>Call Timeline</h2></div>
            <div class="card-body" style="display:grid; grid-template-columns:repeat(auto-fit, minmax(180px,1fr)); gap:12px 24px;">
              {c.dispatch_time && (
                <div><div class="form-label">Dispatch</div><div style="font-size:0.85rem;">{fmtDate(c.dispatch_time)}</div></div>
              )}
              <div><div class="form-label">Incident</div><div style="font-size:0.85rem;">{fmtDate(c.incident_time)}</div></div>
              {c.on_scene_time && (
                <div><div class="form-label">On Scene</div><div style="font-size:0.85rem;">{fmtDate(c.on_scene_time)}</div></div>
              )}
              {c.transport_start && (
                <div><div class="form-label">Transport Start</div><div style="font-size:0.85rem;">{fmtDate(c.transport_start)}</div></div>
              )}
              {c.arrival_time && (
                <div><div class="form-label">Hospital Arrival</div><div style="font-size:0.85rem;">{fmtDate(c.arrival_time)}</div></div>
              )}
              {c.transfer_care_time && (
                <div><div class="form-label">Transfer of Care</div><div style="font-size:0.85rem;">{fmtDate(c.transfer_care_time)}</div></div>
              )}
            </div>
          </div>

          <!-- Transfer Details -->
          <div class="card">
            <div class="card-header"><h2>Transfer Details</h2></div>
            <div class="card-body" style="display:grid; grid-template-columns:1fr 1fr; gap:12px 24px;">
              <div>
                <div class="form-label">Sending Facility</div>
                <div style="font-size:0.875rem;">{c.pickup}</div>
              </div>
              <div>
                <div class="form-label">Receiving Facility</div>
                <div style="font-size:0.875rem;">{c.destination}</div>
              </div>
              {c.transport_mode && (
                <div>
                  <div class="form-label">Transport Mode</div>
                  <div style="font-size:0.875rem; text-transform:capitalize;">{c.transport_mode}</div>
                </div>
              )}
              {c.sending_physician && (
                <div>
                  <div class="form-label">Sending Physician</div>
                  <div style="font-size:0.875rem;">{c.sending_physician}</div>
                </div>
              )}
              {c.sending_diagnosis && (
                <div style="grid-column:1/-1;">
                  <div class="form-label">Sending Diagnosis</div>
                  <div style="font-size:0.875rem;">{c.sending_diagnosis}</div>
                </div>
              )}
              {c.referral_reason && (
                <div>
                  <div class="form-label">Referral Reason</div>
                  <div style="font-size:0.875rem;">{c.referral_reason}</div>
                </div>
              )}
              {c.receiving_provider && (
                <div>
                  <div class="form-label">Receiving Provider</div>
                  <div style="font-size:0.875rem;">{c.receiving_provider}</div>
                </div>
              )}
            </div>
          </div>

          <!-- Patient & SAMPLE -->
          <div class="card">
            <div class="card-header"><h2>Patient &amp; SAMPLE History</h2></div>
            <div class="card-body" style="display:grid; grid-template-columns:1fr 1fr; gap:12px 24px;">
              <div>
                <div class="form-label">Patient</div>
                <div style="font-size:0.875rem;">
                  {c.patient_name ?? 'Unknown'}
                  {c.patient_age ? ` · ${c.patient_age}y` : ''}
                  {c.patient_sex ? ` · ${c.patient_sex}` : ''}
                </div>
              </div>
              <div style="grid-column:1/-1;">
                <div class="form-label">Chief Complaint</div>
                <div style="font-size:0.875rem; font-weight:500;">{c.complaint}</div>
              </div>
              {c.events_leading && (
                <div style="grid-column:1/-1;">
                  <div class="form-label">Events Leading</div>
                  <div style="font-size:0.875rem;">{c.events_leading}</div>
                </div>
              )}
              <div>
                <div class="form-label">Allergies</div>
                <div style="font-size:0.875rem;">{c.allergies ?? 'Not documented'}</div>
              </div>
              <div>
                <div class="form-label">Medications</div>
                <div style="font-size:0.875rem;">{c.current_medications ?? 'Not documented'}</div>
              </div>
              {c.past_medical_hx && (
                <div>
                  <div class="form-label">Past Medical History</div>
                  <div style="font-size:0.875rem;">{c.past_medical_hx}</div>
                </div>
              )}
              {c.last_oral_intake && (
                <div>
                  <div class="form-label">Last Oral Intake</div>
                  <div style="font-size:0.875rem;">{c.last_oral_intake}</div>
                </div>
              )}
            </div>
          </div>

          <!-- Vitals -->
          {(v1 || v2) && (
            <div class="card">
              <div class="card-header"><h2>Vital Signs</h2></div>
              <div class="card-body" style="display:grid; grid-template-columns:1fr 1fr; gap:16px 24px;">
                {v1 && (
                  <div>
                    <div class="form-label" style="margin-bottom:8px;">
                      Set 1 — Initial{v1.time ? ` · ${fmtDate(v1.time)}` : ''}
                    </div>
                    <div style="font-size:0.85rem; line-height:1.8; font-family:monospace;">
                      {fmtVitals(v1) ?? 'No values recorded'}
                    </div>
                  </div>
                )}
                {v2 && (
                  <div>
                    <div class="form-label" style="margin-bottom:8px;">
                      Set 2 — En Route{v2.time ? ` · ${fmtDate(v2.time)}` : ''}
                    </div>
                    <div style="font-size:0.85rem; line-height:1.8; font-family:monospace;">
                      {fmtVitals(v2) ?? 'No values recorded'}
                    </div>
                  </div>
                )}
              </div>
            </div>
          )}

          <!-- Interventions & Crew -->
          {(c.interventions || c.crew_names || c.notes) && (
            <div class="card">
              <div class="card-header"><h2>Interventions &amp; Crew</h2></div>
              <div class="card-body" style="display:grid; grid-template-columns:1fr 1fr; gap:12px 24px;">
                {c.interventions && (
                  <div style="grid-column:1/-1;">
                    <div class="form-label">Interventions</div>
                    <div style="font-size:0.875rem; white-space:pre-line;">{c.interventions}</div>
                  </div>
                )}
                {c.crew_names && (
                  <div>
                    <div class="form-label">Crew</div>
                    <div style="font-size:0.875rem;">{c.crew_names}</div>
                  </div>
                )}
                {c.notes && (
                  <div style="grid-column:1/-1;">
                    <div class="form-label">Additional Notes</div>
                    <div style="font-size:0.875rem;">{c.notes}</div>
                  </div>
                )}
              </div>
            </div>
          )}

          <!-- Triage Severity Score -->
          {triage && (
            <div class="card fade-in" style="animation-delay:20ms;">
              <div class="card-header">
                <h2>AI Triage Assessment</h2>
                <span style={`background:${triageBgc}; color:${triageCol}; font-weight:700; font-size:0.78rem; text-transform:uppercase; letter-spacing:0.06em; padding:4px 12px; border-radius:20px; border:1.5px solid ${triageCol};`}>
                  {triage.color?.toUpperCase()} &mdash; {triage.label}
                </span>
              </div>
              <div class="card-body">
                <div style="display:grid; grid-template-columns:1fr 1fr; gap:14px 24px; font-size:0.875rem;">
                  <div style="grid-column:1/-1;">
                    <div class="form-label">Reasoning</div>
                    <div style="line-height:1.6;">{triage.reasoning}</div>
                  </div>
                  <div>
                    <div class="form-label">Minimum Facility Required</div>
                    <div style="font-weight:600;">{triage.min_facility_level}</div>
                  </div>
                  {triage.time_critical_flags?.length > 0 && (
                    <div>
                      <div class="form-label">Time-Critical Conditions</div>
                      <div style="display:flex; flex-wrap:wrap; gap:6px; margin-top:4px;">
                        {triage.time_critical_flags.map((f: string) => (
                          <span style="background:var(--red-bg); color:var(--red-text); font-size:0.75rem; padding:2px 8px; border-radius:20px; font-weight:500;">{f}</span>
                        ))}
                      </div>
                    </div>
                  )}
                </div>
              </div>
            </div>
          )}

          <!-- PCR Output -->
          <div id="pcr-card" class="card fade-in">
            <div class="card-header">
              <h2>Patient Care Report</h2>
              {gen && (
                <div style="display:flex; align-items:center; gap:10px;">
                  <span style="font-size:0.75rem; color:var(--charcoal-muted);">{gen.model_name} · {fmtDate(gen.created_at)}</span>
                  <button
                    class="btn btn-outline"
                    style="padding:4px 10px; font-size:0.75rem;"
                    onclick="copyPCR()"
                  >Copy</button>
                </div>
              )}
            </div>
            <div class="card-body">
              {gen ? (
                <pre id="pcr-text" style="white-space:pre-wrap; font-family:'Inter',sans-serif; font-size:0.875rem; line-height:1.7; color:var(--charcoal);">{gen.pcr_text}</pre>
              ) : (
                <div class="empty" style="padding:32px;">
                  No PCR generated yet. Click <strong>Generate PCR</strong> above.
                </div>
              )}
            </div>
          </div>

          <!-- Quality Flags -->
          {gen && (
            <div class="card fade-in" style="animation-delay:60ms;">
              <div class="card-header">
                <h2>Quality Flags</h2>
                <span style="font-size:0.8rem; color:var(--charcoal-muted);">{sortedFlags.length} item{sortedFlags.length !== 1 ? 's' : ''}</span>
              </div>
              <div class="card-body" style="padding:12px 20px;">
                {sortedFlags.length === 0 ? (
                  <div style="color:var(--charcoal-muted); font-size:0.85rem; padding:8px 0;">
                    No flags — documentation looks complete.
                  </div>
                ) : (
                  <div style="display:flex; flex-direction:column; gap:8px;">
                    {sortedFlags.map((f: any, i: number) => {
                      const bg   = f.severity === 'high'   ? 'var(--red-bg)'   : f.severity === 'medium' ? 'var(--amber-bg)'   : 'var(--green-soft)';
                      const col  = f.severity === 'high'   ? 'var(--red-text)' : f.severity === 'medium' ? 'var(--amber-text)' : 'var(--green-dark)';
                      const bord = f.severity === 'high'   ? '#fecaca'         : f.severity === 'medium' ? '#fde68a'          : '#c3ddd4';
                      return (
                        <div
                          class="fade-in"
                          style={`background:${bg}; border-left:3px solid ${bord}; border-radius:var(--radius-input); padding:10px 14px; animation-delay:${80 + i*40}ms;`}
                        >
                          <div style={`font-size:0.75rem; font-weight:600; text-transform:uppercase; letter-spacing:0.05em; color:${col}; margin-bottom:3px;`}>
                            {f.severity}
                          </div>
                          <div style="font-size:0.875rem; font-weight:500; margin-bottom:2px;">{f.issue}</div>
                          <div style="font-size:0.8rem; color:var(--charcoal-muted);">{f.action}</div>
                        </div>
                      );
                    })}
                  </div>
                )}
              </div>
            </div>
          )}

          <!-- Recommendation -->
          {gen?.recommendation && (
            <div class="card fade-in" style="animation-delay:120ms;">
              <div class="card-header"><h2>Transfer Recommendation</h2></div>
              <div class="card-body">
                <p style="font-size:0.875rem; line-height:1.7;">{gen.recommendation}</p>
              </div>
            </div>
          )}

          <!-- Ops Snapshot -->
          {hasOps && (
            <div class="card fade-in" style="animation-delay:160ms;">
              <div class="card-header"><h2>Operational Context</h2></div>
              <div class="card-body">
                <div style="display:grid; grid-template-columns:repeat(auto-fit, minmax(220px,1fr)); gap:20px;">
                  <!-- Route -->
                  <div>
                    <div class="form-label" style="margin-bottom:8px;">Route</div>
                    {route ? (
                      <div>
                        <div style="font-size:1.1rem; font-weight:600;">{route.duration_min} min</div>
                        <div style="font-size:0.8rem; color:var(--charcoal-muted);">{route.distance_km} km driving</div>
                      </div>
                    ) : (
                      <div style="font-size:0.85rem; color:var(--charcoal-muted);">Unavailable</div>
                    )}
                  </div>
                  <!-- Weather -->
                  <div>
                    <div class="form-label" style="margin-bottom:8px;">Weather</div>
                    <div style="display:flex; flex-direction:column; gap:6px; font-size:0.83rem;">
                      <div><span style="color:var(--charcoal-muted);">Pickup:</span> {wxLine(weather?.pickup)}</div>
                      <div><span style="color:var(--charcoal-muted);">Destination:</span> {wxLine(weather?.destination)}</div>
                    </div>
                  </div>
                  <!-- Facilities -->
                  {facilities.length > 0 && (
                    <div>
                      <div class="form-label" style="margin-bottom:8px;">Nearby Facilities</div>
                      <div style="display:flex; flex-direction:column; gap:4px;">
                        {facilities.map((f: any) => (
                          <div style="font-size:0.82rem;">
                            <span style="font-weight:500;">{f.name}</span>
                            <span style="color:var(--charcoal-muted);"> · {f.type}</span>
                          </div>
                        ))}
                      </div>
                    </div>
                  )}
                </div>
              </div>
            </div>
          )}
          <!-- Outcome Feedback -->
          {c?.outcome_token && (
            <div class="card fade-in" style="animation-delay:200ms;">
              <div class="card-header">
                <h2>Patient Outcome</h2>
                {outcome && (
                  <span style="font-size:0.75rem; background:var(--green-soft); color:var(--green-dark); padding:2px 10px; border-radius:20px; font-weight:600;">
                    Outcome received
                  </span>
                )}
              </div>
              <div class="card-body">
                {outcome ? (
                  <div style="display:grid; grid-template-columns:1fr 1fr; gap:12px 24px; font-size:0.875rem;">
                    <div>
                      <div class="form-label">Patient Status</div>
                      <div style="font-weight:600; text-transform:capitalize;">{outcome.patient_status}</div>
                    </div>
                    {outcome.admission_ward && (
                      <div>
                        <div class="form-label">Admission Ward</div>
                        <div>{outcome.admission_ward}</div>
                      </div>
                    )}
                    {outcome.confirmed_diagnosis && (
                      <div style="grid-column:1/-1;">
                        <div class="form-label">Confirmed Diagnosis</div>
                        <div style="font-weight:500;">{outcome.confirmed_diagnosis}</div>
                      </div>
                    )}
                    {outcome.notes && (
                      <div style="grid-column:1/-1;">
                        <div class="form-label">Notes from Hospital</div>
                        <div style="white-space:pre-line;">{outcome.notes}</div>
                      </div>
                    )}
                    <div style="grid-column:1/-1; font-size:0.78rem; color:var(--charcoal-muted);">
                      Submitted by receiving hospital
                    </div>
                  </div>
                ) : (
                  <div>
                    <p style="font-size:0.85rem; color:var(--charcoal-muted); margin-bottom:16px;">
                      No outcome submitted yet. Share this link with the receiving hospital so they can record what happened to this patient.
                    </p>
                    <div style="display:flex; align-items:center; gap:10px; flex-wrap:wrap;">
                      <input
                        id="outcome-url"
                        type="text"
                        class="form-control"
                        style="flex:1; min-width:200px; font-size:0.8rem; font-family:monospace;"
                        value={`/outcomes/${c.outcome_token}`}
                        readonly
                      />
                      <button class="btn btn-outline" onclick="copyOutcomeLink()" style="white-space:nowrap;">Copy Link</button>
                    </div>
                  </div>
                )}
              </div>
            </div>
          )}


        </div>
      </>
    )}
  </div>
</Base>

<script>
  const API = import.meta.env.PUBLIC_API_URL ?? 'http://localhost:8000';

  function getToken(): string {
    return document.cookie.split(';').find(c => c.trim().startsWith('nas_token='))?.split('=')[1] ?? '';
  }

  async function handleGenerate(id: string) {
    const btn = document.getElementById('btn-generate') as HTMLButtonElement;
    const label = document.getElementById('gen-label')!;
    const spinner = document.getElementById('gen-spinner')!;
    const errBanner = document.getElementById('action-error')!;

    btn.disabled = true;
    label.textContent = 'Generating…';
    spinner.style.display = 'inline-block';
    errBanner.style.display = 'none';

    try {
      const res = await fetch(`${API}/cases/${id}/generate`, { method: 'POST', headers: { Authorization: `Bearer ${getToken()}` } });
      if (res.ok) {
        window.location.reload();
      } else {
        const err = await res.json().catch(() => ({}));
        errBanner.textContent = err.detail ?? `Generation failed (${res.status})`;
        errBanner.style.display = 'block';
      }
    } catch (e: any) {
      errBanner.textContent = e.message ?? 'Could not reach backend';
      errBanner.style.display = 'block';
    } finally {
      btn.disabled = false;
      label.textContent = 'Generate PCR';
      spinner.style.display = 'none';
    }
  }

  async function handleFinalize(id: string) {
    const errBanner = document.getElementById('action-error')!;
    errBanner.style.display = 'none';
    try {
      const res = await fetch(`${API}/cases/${id}/finalize`, { method: 'PATCH', headers: { Authorization: `Bearer ${getToken()}` } });
      if (res.ok) window.location.reload();
      else {
        const err = await res.json().catch(() => ({}));
        errBanner.textContent = err.detail ?? `Finalize failed (${res.status})`;
        errBanner.style.display = 'block';
      }
    } catch (e: any) {
      errBanner.textContent = e.message ?? 'Could not reach backend';
      errBanner.style.display = 'block';
    }
  }

  function copyPCR() {
    const text = document.getElementById('pcr-text')?.textContent ?? '';
    navigator.clipboard.writeText(text).then(() => {
      const btn = document.querySelector('[onclick="copyPCR()"]') as HTMLButtonElement;
      if (btn) { btn.textContent = 'Copied!'; setTimeout(() => { btn.textContent = 'Copy'; }, 1800); }
    });
  }

  function copyOutcomeLink() {
    const inp = document.getElementById('outcome-url') as HTMLInputElement;
    if (!inp) return;
    inp.value = window.location.origin + inp.value;
    navigator.clipboard.writeText(inp.value).then(() => {
      const btn = document.querySelector('[onclick="copyOutcomeLink()"]') as HTMLButtonElement;
      if (btn) { btn.textContent = 'Copied!'; setTimeout(() => { btn.textContent = 'Copy Link'; }, 1800); }
    });
  }

  // expose to inline onclick
  (window as any).handleGenerate = handleGenerate;
  (window as any).handleFinalize = handleFinalize;
  (window as any).copyPCR = copyPCR;
  (window as any).copyOutcomeLink = copyOutcomeLink;
</script>
