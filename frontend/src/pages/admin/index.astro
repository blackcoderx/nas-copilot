---
import Base from '../../layouts/Base.astro';

const API   = import.meta.env.PUBLIC_API_URL ?? 'http://localhost:8000';
const token = Astro.cookies.get('nas_token')?.value;

// Fetch staff and cases for this hospital
let staff: any[] = [];
let cases: any[] = [];
let fetchError = '';

try {
  const [staffRes, casesRes] = await Promise.all([
    fetch(`${API}/auth/users`, { headers: { Authorization: `Bearer ${token}` } }),
    fetch(`${API}/cases`,      { headers: { Authorization: `Bearer ${token}` } }),
  ]);

  if (staffRes.status === 401 || casesRes.status === 401) return Astro.redirect('/login');

  if (staffRes.ok) staff = await staffRes.json();
  else fetchError = 'Could not load staff list';

  if (casesRes.ok) cases = await casesRes.json();
} catch {
  fetchError = 'Could not reach backend';
}

function fmtDate(iso: string) {
  return new Date(iso).toLocaleString('en-GB', {
    day: '2-digit', month: 'short', year: 'numeric',
    hour: '2-digit', minute: '2-digit',
  });
}

function timeAgo(iso: string) {
  const diff = Date.now() - new Date(iso).getTime();
  const m = Math.floor(diff / 60000);
  if (m < 60) return `${m}m ago`;
  const h = Math.floor(m / 60);
  if (h < 24) return `${h}h ago`;
  return `${Math.floor(h / 24)}d ago`;
}
---

<Base title="Admin Panel">
  <div class="page">
    <div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:28px; flex-wrap:wrap; gap:12px;">
      <div>
        <h1>Admin Panel</h1>
        <p style="font-size:0.85rem; color:var(--charcoal-muted); margin-top:4px;">
          Manage your hospital's staff and view all cases.
        </p>
      </div>
      <a href="/admin/users/new" class="btn btn-primary">+ Add Staff Member</a>
    </div>

    {fetchError && (
      <div style="background:var(--red-bg); color:var(--red-text); border:1px solid #fecaca; border-radius:var(--radius-card); padding:14px 18px; margin-bottom:20px; font-size:0.85rem;">
        {fetchError}
      </div>
    )}

    <!-- Staff table -->
    <div class="card" style="margin-bottom:24px;">
      <div class="card-header">
        <h2>Staff Members</h2>
        <span style="font-size:0.8rem; color:var(--charcoal-muted);">{staff.length} member{staff.length !== 1 ? 's' : ''}</span>
      </div>
      <div class="card-body" style="padding:0;">
        {staff.length === 0 ? (
          <div class="empty">No staff yet. <a href="/admin/users/new" style="color:var(--green); text-decoration:underline;">Add your first EMT.</a></div>
        ) : (
          <table style="width:100%; border-collapse:collapse; font-size:0.85rem;">
            <thead>
              <tr style="border-bottom:1px solid var(--border);">
                <th style="padding:10px 20px; text-align:left; font-weight:500; color:var(--charcoal-muted);">Name</th>
                <th style="padding:10px 20px; text-align:left; font-weight:500; color:var(--charcoal-muted);">Username</th>
                <th style="padding:10px 20px; text-align:left; font-weight:500; color:var(--charcoal-muted);">Role</th>
                <th style="padding:10px 20px; text-align:left; font-weight:500; color:var(--charcoal-muted);">Joined</th>
              </tr>
            </thead>
            <tbody>
              {staff.map((s: any) => (
                <tr style="border-bottom:1px solid var(--border);">
                  <td style="padding:12px 20px;">{s.full_name ?? '—'}</td>
                  <td style="padding:12px 20px; font-family:monospace; font-size:0.82rem;">{s.username}</td>
                  <td style="padding:12px 20px;">
                    <span class={`badge badge-${s.role === 'admin' ? 'final' : 'draft'}`}>{s.role.toUpperCase()}</span>
                  </td>
                  <td style="padding:12px 20px; color:var(--charcoal-muted);">{fmtDate(s.created_at)}</td>
                </tr>
              ))}
            </tbody>
          </table>
        )}
      </div>
    </div>

    <!-- Cases table -->
    <div class="card">
      <div class="card-header">
        <h2>All Cases</h2>
        <span style="font-size:0.8rem; color:var(--charcoal-muted);">{cases.length} case{cases.length !== 1 ? 's' : ''}</span>
      </div>
      <div class="card-body" style="padding:0;">
        {cases.length === 0 ? (
          <div class="empty">No cases recorded yet.</div>
        ) : (
          <table style="width:100%; border-collapse:collapse; font-size:0.85rem;">
            <thead>
              <tr style="border-bottom:1px solid var(--border);">
                <th style="padding:10px 20px; text-align:left; font-weight:500; color:var(--charcoal-muted);">Complaint</th>
                <th style="padding:10px 20px; text-align:left; font-weight:500; color:var(--charcoal-muted);">Route</th>
                <th style="padding:10px 20px; text-align:left; font-weight:500; color:var(--charcoal-muted);">Status</th>
                <th style="padding:10px 20px; text-align:left; font-weight:500; color:var(--charcoal-muted);">Created</th>
              </tr>
            </thead>
            <tbody>
              {cases.map((c: any) => (
                <tr style="border-bottom:1px solid var(--border); cursor:pointer;" onclick={`window.location='/cases/${c.id}'`}>
                  <td style="padding:12px 20px; font-weight:500;">{c.complaint}</td>
                  <td style="padding:12px 20px; font-size:0.8rem; color:var(--charcoal-muted);">{c.pickup} → {c.destination}</td>
                  <td style="padding:12px 20px;">
                    <span class={`badge badge-${c.status.toLowerCase()}`}>{c.status}</span>
                  </td>
                  <td style="padding:12px 20px; color:var(--charcoal-muted);">{timeAgo(c.created_at)}</td>
                </tr>
              ))}
            </tbody>
          </table>
        )}
      </div>
    </div>
  </div>
</Base>
